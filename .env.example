TELEGRAM_BOT_TOKEN=1234567890:your-telegram-bot-token
OPENAI_API_KEY=sk-your-openai-api-key
PINECONE_API_KEY=pc-your-pinecone-api-key
PINECONE_INDEX_NAME=telegram-bot-memories
PINECONE_RAG_INDEX_NAME=telegram-bot-rag
PINECONE_REGION=us-east-1
RAG_INIT_FROM_DATA_FILE=false
RUN_INDEXING_ON_START=false

# Тестовые запросы к обоим индексам Pinecone перед запуском long polling (true/false, по умолчанию true)
# PINECONE_STARTUP_CHECK=true
# Завершить процесс, если проверка не прошла (по умолчанию false — только предупреждение в логе)
# PINECONE_STRICT_STARTUP=false

# Уровень логирования: DEBUG, INFO (по умолчанию), WARNING, ERROR
LOG_LEVEL=INFO
# Количество top-результатов Pinecone, выводимых в логах
LOG_PINECONE_TOP_K=3

# Telegram user_id (через запятую), кому разрешена кнопка «Очистить индексы» (удаление всех векторов в обоих индексах)
# CLEAR_INDEXES_ALLOWED_USER_IDS=123456789

# Опционально можно переопределить модели:
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_MODEL=gpt-4o-mini

